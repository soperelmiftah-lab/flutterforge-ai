// FlutterForge AI — Prisma schema (v1.1.0)
//
// PostgreSQL (Supabase) for both dev and production.
// All state tables include userId for multi-tenancy + Row Level Security.
//
// Tables by phase:
//   Auth:     accounts, sessions, verification_tokens, users
//   Phase 1:  projects, project_files, workspaces, settings, chat_sessions, messages
//   Phase 2:  ai_credentials, ai_usage_records
//   Phase 5:  planner_sessions, planner_tasks
//   Phase 6:  tool_chains, tool_executions, tool_learning
//   Phase 7:  generated_code
//   Phase 8:  run_sessions, build_jobs, runtime_logs, runtime_history
//   Phase 9:  visual_sessions, screenshots, visual_events, visual_console, frame_stats
//   Phase 10: vision_reports, vision_history
//   Phase 11: autonomous_pipelines, autonomous_sessions, autonomous_history, autonomous_learning
//   Phase 12: cloud_workers, cloud_jobs, artifacts, cloud_logs, cloud_history

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════════════════
// AUTH (NextAuth.js + Prisma Adapter)
// ═══════════════════════════════════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  avatarUrl     String?
  emailVerified DateTime?
  plan          String    @default("free") // free | pro | team
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  projects        Project[]
  settings        Settings?
  chatSessions    ChatSession[]

  // Phase 5-12 relations
  plannerSessions     PlannerSession[]
  toolChains          ToolChain[]
  generatedCode       GeneratedCode[]
  runSessions         RunSession[]
  buildJobs           BuildJob[]
  runtimeLogs         RuntimeLog[]
  runtimeHistory      RuntimeHistory[]
  visualSessions      VisualSession[]
  screenshots         Screenshot[]
  visualEvents        VisualEvent[]
  visualConsole       VisualConsoleEntry[]
  frameStats          FrameStat[]
  visionReports       VisionReport[]
  visionHistory       VisionHistory[]
  autonomousPipelines AutonomousPipeline[]
  autonomousHistory   AutonomousHistory[]
  autonomousLearning  AutonomousLearning[]
  cloudJobs           CloudJob[]
  artifacts           Artifact[]
  cloudLogs           CloudLog[]
  cloudHistory        CloudHistory[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 1: Foundation
// ═══════════════════════════════════════════════════════════════════════════

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String   @default("")
  framework     String   @default("Flutter 3.22")
  status        String   @default("draft")
  favorite      Boolean  @default(false)
  color         String   @default("emerald")
  filesCount    Int      @default(0)
  collaborators Int      @default(1)
  ownerId       String

  owner       User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  files       ProjectFile[]
  workspace   Workspace?

  lastOpenedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ownerId])
  @@map("projects")
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  name       String
  path       String
  type       String
  language   String?
  content    String?
  parentPath String?

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, path])
  @@index([projectId])
  @@map("project_files")
}

model Workspace {
  id          String   @id @default(cuid())
  projectId   String   @unique
  openTabs    String   @default("[]")
  activeTabId String?
  layout      String   @default("{}")
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model Settings {
  id          String  @id @default(cuid())
  userId      String  @unique
  theme       String  @default("dark")
  language    String  @default("en")
  fontSize    Int     @default(14)
  editorTheme String  @default("forge-dark")
  autoSave    Boolean @default(true)
  tabSize     Int     @default(2)
  wordWrap    Boolean @default(true)
  minimap     Boolean @default(true)
  lineNumbers Boolean @default(true)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("New chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("messages")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 2: AI Core
// ═══════════════════════════════════════════════════════════════════════════

model AiCredential {
  id        String   @id @default(cuid())
  provider  String   @unique
  encrypted String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_credentials")
}

model AiUsageRecord {
  id           String   @id @default(cuid())
  userId       String?
  provider     String
  model        String
  inputTokens  Int
  outputTokens Int
  totalTokens  Int
  sessionId    String?
  createdAt    DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
  @@index([userId])
  @@map("ai_usage_records")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 5: Planner & Agents
// ═══════════════════════════════════════════════════════════════════════════

model PlannerSession {
  id         String   @id @default(cuid())
  userId     String
  input      String
  intentType String
  goalJson   String   @default("{}") // JSON: full goal
  planJson   String   @default("{}") // JSON: full plan with tasks
  status     String   @default("draft") // draft | executing | completed | failed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("planner_sessions")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 6: Tool Intelligence
// ═══════════════════════════════════════════════════════════════════════════

model ToolChain {
  id          String   @id @default(cuid())
  userId      String
  objective   String
  intentType  String?
  chainJson   String   @default("{}") // JSON: full chain with steps
  rationale   String   @default("")
  aiGenerated Boolean  @default(false)
  optimized   Boolean  @default(false)
  createdAt   DateTime @default(now())

  executions  ToolExecution[]
  learning    ToolLearningRecord[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tool_chains")
}

model ToolExecution {
  id          String   @id @default(cuid())
  chainId     String
  userId      String
  status      String   @default("running") // running | completed | partial | failed
  successCount Int     @default(0)
  failureCount Int     @default(0)
  skippedCount Int     @default(0)
  durationMs  Int      @default(0)
  tokensUsed  Int      @default(0)
  stepsJson   String   @default("[]") // JSON: per-step execution results
  createdAt   DateTime @default(now())

  chain ToolChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  @@index([chainId])
  @@index([userId])
  @@map("tool_executions")
}

model ToolLearningRecord {
  id         String   @id @default(cuid())
  toolId     String
  chainId    String
  userId     String
  success    Boolean
  durationMs Int
  tokensUsed Int
  learnedAt  DateTime @default(now())

  chain ToolChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  @@index([toolId])
  @@index([chainId])
  @@map("tool_learning")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 7: Flutter Platform
// ═══════════════════════════════════════════════════════════════════════════

model GeneratedCode {
  id            String   @id @default(cuid())
  userId        String
  description   String
  mode          String   // screen | widget | model | service
  className     String
  code          String
  suggestedPath String
  lineCount     Int
  rationale     String   @default("")
  aiGenerated   Boolean  @default(false)
  saved         Boolean  @default(false)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("generated_code")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 8: Runtime Platform
// ═══════════════════════════════════════════════════════════════════════════

model RunSession {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  deviceId        String
  status          String   @default("starting") // starting | running | stopped | error
  pid             Int?
  logsJson        String   @default("[]") // JSON: array of log strings
  hotReloadCount  Int      @default(0)
  hotRestartCount Int      @default(0)
  startedAt       DateTime @default(now())
  finishedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("run_sessions")
}

model BuildJob {
  id           String   @id @default(cuid())
  userId       String
  target       String   // apk | aab | web | ios | macos | windows | linux
  mode         String   // debug | profile | release
  status       String   @default("queued") // queued | running | success | failed
  progress     Int      @default(0)
  logsJson     String   @default("[]") // JSON: array of log strings
  artifactPath String?
  durationMs   Int?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("build_jobs")
}

model RuntimeLog {
  id        String   @id @default(cuid())
  userId    String
  level     String   // debug | info | warning | error | fatal
  source    String   // flutter | dart | gradle | adb | build | runtime | test
  message   String
  pid       Int?
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@map("runtime_logs")
}

model RuntimeHistory {
  id         String   @id @default(cuid())
  userId     String
  action     String   // create | open | build | run | test | analyze | pub | hotreload | hotrestart
  projectId  String?
  success    Boolean
  durationMs Int
  details    String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("runtime_history")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 9: Visual Runtime
// ═══════════════════════════════════════════════════════════════════════════

model VisualSession {
  id             String   @id @default(cuid())
  userId         String
  deviceId       String
  status         String   @default("active") // active | stopped
  screenshotCount Int     @default(0)
  streamDurationMs Int    @default(0)
  logCount       Int      @default(0)
  eventCount     Int      @default(0)
  connectedAt    DateTime @default(now())
  disconnectedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("visual_sessions")
}

model Screenshot {
  id         String   @id @default(cuid())
  userId     String
  deviceId   String
  dataUrl    String
  width      Int
  height     Int
  orientation String  @default("portrait")
  appPackage String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@map("screenshots")
}

model VisualEvent {
  id        String   @id @default(cuid())
  userId    String
  type      String   // tap | long-press | scroll | navigation | keyboard | lifecycle
  detailsJson String @default("{}") // JSON: event details
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("visual_events")
}

model VisualConsoleEntry {
  id         String   @id @default(cuid())
  userId     String
  level      String   // debug | info | warning | error | fatal
  source     String   // flutter | dart | platform | gradle
  message    String
  stackTrace String?
  timestamp  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([level])
  @@map("visual_console")
}

model FrameStat {
  id               String   @id @default(cuid())
  userId           String
  fps              Int
  droppedFrames    Int
  avgFrameDurationMs Float
  maxFrameDurationMs Float
  jankCount        Int
  isJanky          Boolean  @default(false)
  timestamp        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("frame_stats")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 10: Vision AI
// ═══════════════════════════════════════════════════════════════════════════

model VisionReport {
  id              String   @id @default(cuid())
  userId          String
  deviceId        String
  overallScore    Int
  executiveSummary String
  reportJson      String   @default("{}") // JSON: full report (all 6 dimensions)
  aiGenerated     Boolean  @default(false)
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("vision_reports")
}

model VisionHistory {
  id           String   @id @default(cuid())
  userId       String
  reportId     String
  deviceId     String
  overallScore Int
  confidence   Float
  issueCount   Int
  timestamp    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("vision_history")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 11: Autonomous Engineering
// ═══════════════════════════════════════════════════════════════════════════

model AutonomousPipeline {
  id         String   @id @default(cuid())
  userId     String
  problemId  String
  status     String   @default("active") // active | completed | failed
  stepsJson  String   @default("[]") // JSON: 10-stage pipeline steps
  resultJson String   @default("{}") // JSON: full pipeline result
  aiEnhanced Boolean  @default(false)
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("autonomous_pipelines")
}

model AutonomousHistory {
  id           String   @id @default(cuid())
  userId       String
  problemTitle String
  category     String
  success      Boolean
  durationMs   Int
  confidence   Float
  rolledBack   Boolean  @default(false)
  timestamp    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("autonomous_history")
}

model AutonomousLearning {
  id              String   @id @default(cuid())
  userId          String
  problemCategory String
  repairStrategy  String
  success         Boolean
  confidence      Float
  durationMs      Int
  learnedAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("autonomous_learning")
}

// ═══════════════════════════════════════════════════════════════════════════
// PHASE 12: Cloud Platform
// ═══════════════════════════════════════════════════════════════════════════

model CloudWorker {
  id             String   @id @default(cuid())
  name           String
  type           String   // local | docker | remote | cloud | ci
  status         String   @default("idle") // idle | busy | offline | error
  capabilitiesJson String @default("[]") // JSON: array of capability strings
  cpuUsage       Float    @default(0)
  memoryUsage    Float    @default(0)
  maxJobs        Int      @default(2)
  activeJobs     Int      @default(0)
  lastHeartbeat  DateTime @default(now())
  address        String?
  createdAt      DateTime @default(now())

  @@map("cloud_workers")
}

model CloudJob {
  id              String   @id @default(cuid())
  userId          String
  type            String   // build | run | test | analyze | pub | custom
  command         String
  argsJson        String   @default("[]")
  status          String   @default("queued") // queued | running | success | failed | cancelled | timeout
  runtimeType     String   @default("local") // local | docker | remote | cloud | ci
  workerId        String?
  projectId       String?
  priority        Int      @default(0)
  exitCode        Int?
  stdoutJson      String   @default("[]")
  stderrJson      String   @default("[]")
  retries         Int      @default(0)
  maxRetries      Int      @default(3)
  timeoutMs       Int      @default(120000)
  durationMs      Int?
  enqueuedAt      DateTime @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("cloud_jobs")
}

model Artifact {
  id         String   @id @default(cuid())
  userId     String
  jobId      String
  type       String   // apk | aab | zip | coverage | logs | report | screenshot
  name       String
  path       String
  sizeMb     Float
  signed     Boolean  @default(false)
  createdAt  DateTime @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
  @@map("artifacts")
}

model CloudLog {
  id        String   @id @default(cuid())
  userId    String
  level     String   // info | warning | error
  message   String
  timestamp DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cloud_logs")
}

model CloudHistory {
  id          String   @id @default(cuid())
  userId      String
  jobId       String
  type        String
  runtimeType String
  success     Boolean
  durationMs  Int
  workerName  String?
  timestamp   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("cloud_history")
}
