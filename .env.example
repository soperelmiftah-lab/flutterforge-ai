# ═══════════════════════════════════════════════════════════════════════════
# FlutterForge AI — Environment Configuration (v1.1.0)
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in the values for your environment.
# All values below are examples — replace with your actual secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ─── AI Encryption ──────────────────────────────────────────────────────────
# Used to encrypt stored API keys (provider credentials). Generate a random
# 32+ character string: openssl rand -base64 32
AI_ENCRYPTION_KEY=change-this-to-a-random-32-char-string-in-production

# ─── Authentication (NextAuth.js) ───────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-random-string
# The canonical URL of your deployment (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# ─── GitHub OAuth ───────────────────────────────────────────────────────────
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
# For production: https://your-domain.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API requests.
ALLOWED_ORIGINS=http://localhost:3000,https://flutterforge-ai.vercel.app

# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Max API requests per minute per IP (default: 100).
RATE_LIMIT_MAX_REQUESTS=100

# ─── AI Providers (all optional — Forge provider works without keys) ────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_AI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# TOGETHER_AI_API_KEY=
# DEEPSEEK_API_KEY=

# ─── Monitoring (optional) ──────────────────────────────────────────────────
# Sentry DSN for error tracking.
# SENTRY_DSN=
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ─── Deployment ─────────────────────────────────────────────────────────────
NODE_ENV=development
