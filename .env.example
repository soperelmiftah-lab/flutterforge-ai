# ═══════════════════════════════════════════════════════════════════════════
# FlutterForge AI — Environment Configuration (v1.0.0)
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in the values for your environment.
# All values below are examples — replace with your actual secrets.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────────────────────
# SQLite for development, PostgreSQL/MySQL for production.
# Production example: postgresql://user:pass@host:5432/flutterforge
DATABASE_URL=file:./db/flutterforge.db

# ─── AI Encryption ──────────────────────────────────────────────────────────
# Used to encrypt stored API keys (provider credentials). Generate a random
# 32+ character string: openssl rand -base64 32
AI_ENCRYPTION_KEY=change-this-to-a-random-32-char-string-in-production

# ─── Authentication (NextAuth.js) ───────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=change-this-to-a-random-string
# The canonical URL of your deployment (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# ─── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for API requests.
# Use * to allow all (not recommended for production).
ALLOWED_ORIGINS=https://flutterforge-ai.vercel.app,http://localhost:3000

# ─── Rate Limiting ──────────────────────────────────────────────────────────
# Max API requests per minute per IP (default: 100).
RATE_LIMIT_MAX_REQUESTS=100

# ─── AI Providers (all optional — Forge provider works without keys) ────────
# Only set if you want to use external AI providers.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENROUTER_API_KEY=
# GOOGLE_AI_API_KEY=
# MISTRAL_API_KEY=
# GROQ_API_KEY=
# TOGETHER_AI_API_KEY=
# DEEPSEEK_API_KEY=

# ─── Monitoring (optional) ──────────────────────────────────────────────────
# Sentry DSN for error tracking.
# SENTRY_DSN=
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# ─── Deployment ─────────────────────────────────────────────────────────────
# Set to production in production deployments.
NODE_ENV=development
